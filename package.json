{
  "name": "async-race",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "lint-staged": {
    "*.{ts,js}": [
      "prettier --write",
      "eslint --fix"
    ],
    "*.{json,css,scss,md,html}": [
      "prettier --write"
    ]
  },
  "validate-branch-name": {
    "pattern": "^(master|main|develop|async-race)$|^(init|feat|fix|hotfix|release)/[A-Z]+-[A-Z]+-\\d+_[a-zA-Z][a-zA-Z0-9]*$",
    "errorMsg": "Error: incorrect branch name. Example: feat/Async-Race-01_implementLoginForm"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build && cp dist/index.html dist/404.html",
    "preview": "vite preview",
    "prepare": "husky",
    "format": "prettier --write src",
    "ci:format": "prettier --check src",
    "lint": "eslint src --ext .ts,.js",
    "lint:fix": "eslint src --ext .ts,.js --fix",
    "test": "npm run format && npm run lint:fix && npm run lint"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@types/node": "^25.0.7",
    "@typescript-eslint/eslint-plugin": "^8.53.0",
    "@typescript-eslint/parser": "^8.53.0",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "eslint-plugin-unicorn": "^62.0.0",
    "globals": "^17.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "prettier": "^3.7.4",
    "typescript": "~5.9.3",
    "validate-branch-name": "^1.3.2",
    "vite": "^7.2.4"
  }
}
